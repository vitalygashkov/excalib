{
  "name": "excalidraw-shelf",
  "version": "0.1.0",
  "private": true,
  "description": "Manage Excalidraw scenes and sync them with cloud storage",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-solid": "^0.564.0",
    "solid-js": "^1.9.11",
    "solid-sonner": "^0.2.8",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@wxt-dev/module-solid": "^1.1.4",
    "jsdom": "^28.0.0",
    "oxfmt": "^0.32.0",
    "oxlint": "^1.47.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wxt": "^0.20.17"
  },
  "packageManager": "pnpm@10.28.1"
}
